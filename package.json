{
  "name": "cast-swarm",
  "version": "1.0.0",
  "description": "CAST — Coordinated Agent Swarm Testing. Orchestrate Claude AI agents to perform systematic code analysis on any codebase.",
  "type": "module",
  "bin": {
    "cast-swarm": "dist/cli.js",
    "cast-swarm-mcp": "dist/mcp-server.js"
  },
  "main": "dist/core/orchestrator.js",
  "types": "dist/core/orchestrator.d.ts",
  "exports": {
    ".": {
      "import": "./dist/core/orchestrator.js",
      "types": "./dist/core/orchestrator.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp-server.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "NOTICE", "CITATION.cff"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "cast": "tsx src/cli.ts",
    "dry": "tsx src/cli.ts --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["cast", "testing", "claude", "ai", "code-analysis", "mcp", "swarm", "anthropic"],
  "author": "Julie Golston <juliegolston@gmail.com>",
  "license": "Apache-2.0"
}
